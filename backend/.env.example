DATABASE_URL=postgresql+psycopg://tracedog:tracedog@localhost:5432/tracedog
DEBUG=false

# Reliability: tfidf (default, no torch) | sentence_transformers | auto
SIMILARITY_BACKEND=tfidf
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Optional: enables POST /api/v1/admin/experiments/... (Bearer token).
# ADMIN_API_KEY=generate-a-long-random-secret

# Comma-separated browser origins allowed for CORS (add your Vercel URL in prod).
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
